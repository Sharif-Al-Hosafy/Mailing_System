rt React, { useEffect, useState } from 'react'\r\nimport { Button, Table } from 'reactstrap'\r\n//import DocScreen from '../pages/DocScreen.html'\r\nimport { useNavigate } from 'react-router-dom'\r\nimport axios from 'axios'\r\n\r\nconst DailyScreen = () => {\r\n  let navigate = useNavigate()\r\n  let cnt = 0\r\n  const [docs, setDocs] = useState([])\r\n\r\n  useEffect(() => {\r\n    const fetchDocs = async () => {\r\n      const { data } = await axios.get('/api/v1/files/daily/show')\r\n      setDocs(data)\r\n    }\r\n\r\n    fetchDocs()\r\n  }, [])\r\n\r\n  let getData = async (id) => {\r\n    console.log('hiii')\r\n    const data = await axios.get(`/api/v1/files/open/${id}`)\r\n  }\r\n\r\n  return (\r\n    <div>\r\n      <div className='d-flex justify-content-between'>\r\n        <Button\r\n          className='float-right'\r\n          color='danger'\r\n          onClick={() => navigate('/')}\r\n        >\r\n          خروج\r\n        </Button>\r\n        <Button color='success' onClick={() => navigate('/add')}>\r\n          +\r\n        </Button>\r\n      </div>\r\n\r\n      <h1 className='text-center my-5'>المكاتبات اليومية</h1>\r\n      <div className='container text-center'>\r\n        <Table className='table table-hover'>\r\n          <thead>\r\n            <tr>\r\n              <th scope='col'>الملخص</th>\r\n              <th scope='col'>اسم المكاتبة</th>\r\n              <th scope='col'>م</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody>\r\n            {docs.map((el) => (\r\n              <tr\r\n                onClick={async () => {\r\n                  await getData(el.file_no)\r\n                  await axios('/api/v1/files')\r\n                }}\r\n              >\r\n                <td style={{ width: '45%' }}>{el.summary}</td>\r\n                <td style={{ width: '45%' }}>{el.orgname}</td>\r\n                <th style={{ width: '10%' }} scope='row'>\r\n                  {++cnt}\r\n                </th>\r\n              </tr>\r\n            ))}\r\n          </tbody>\r\n        </Table>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\nexport default DailyScreen\r\n","C:\\Users\\Pro1\\Desktop\\mm\\src\\index.js",[],"C:\\Users\\Pro1\\Desktop\\mm\\src\\App.js",[],["64","65"],"C:\\Users\\Pro1\\Desktop\\mm\\src\\pages\\AddScreen.js",[],"C:\\Users\\Pro1\\Desktop\\mm\\src\\pages\\HomeScreen.js",[],"C:\\Users\\Pro1\\Desktop\\mm\\src\\pages\\DailyScreen.js",["66"],"C:\\Users\\Pro1\\Desktop\\mm\\src\\pages\\LoginScreen.js",[],"C:\\Users\\Pro1\\Desktop\\mm\\src\\pages\\DocScreen.js",[],{"ruleId":"67","replacedBy":"68"},{"ruleId":"69","replacedBy":"70"},{"ruleId":"67","replacedBy":"71"},{"ruleId":"69","replacedBy":"72"},{"ruleId":"73","severity":1,"message":"74","line":23,"column":11,"nodeType":"75","messageId":"76","endLine":23,"endColumn":15},{"ruleId":"67","replacedBy":"77"},{"ruleId":"69","replacedBy":"78"},{"ruleId":"73","severity":1,"message":"74","line":23,"column":11,"nodeType":"75","messageId":"76","endLine":23,"endColumn":15},"no-native-reassign",["79"],"no-negated-in-lhs",["80"],["79"],["80"],"no-unused-vars","'data' is assigned a value but never used.","Identifier","unusedVar",["79"],["80"],"no-global-assign","no-unsafe-negation"]